---
import Logo from "./ui/Logo.vue";
---

<footer class="border-t border-border bg-background">
    <div
        class="container mx-auto flex flex-col items-center justify-between gap-4 px-6 py-8 md:flex-row"
    >
        <div class="flex">
            <Logo size="sm" />
        </div>

        <p class="text-xs text-muted-foreground">
            © 2026 Short.rs. All rights reserved.
        </p>

        <div class="flex items-center gap-2 px-3 py-1.5">
            <div
                class="h-1.5 w-1.5 rounded-full bg-rust animate-pulse-glow shadow-[0_0_8px_rgba(244,102,35,0.5)]"
            >
            </div>
            <span class="text-xs text-muted-foreground"
                >Built with Rust & Axum</span
            >
        </div>
    </div>
</footer>
