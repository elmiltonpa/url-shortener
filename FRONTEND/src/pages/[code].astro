---
import { API_URL } from "astro:env/server";

const { code } = Astro.params;

if (!code || !/^[a-zA-Z0-9]{8}$/.test(code)) {
    return Astro.rewrite("/error?code=404");
}

try {
    const response = await fetch(`${API_URL}/${code}`, {
        redirect: "manual",
    });

    if ([301, 302, 303, 307, 308].includes(response.status)) {
        const location = response.headers.get("Location");
        if (location) {
            return Astro.redirect(location, response.status);
        }
    }

    if (response.status === 410) {
        return Astro.rewrite("/error?code=410");
    }

    return Astro.rewrite("/error?code=404");
} catch (e) {
    console.error("[redirect] Failed to resolve short URL:", e);
    return Astro.rewrite("/error?code=500");
}
---
